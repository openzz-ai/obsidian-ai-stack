# ── RAG Service Configuration ────────────────────────────────────────────────
# Copy this file to .env and fill in your values

# Path to your Obsidian vault on the host (mounted read-only into container)
VAULT_PATH=/mnt/user/appdata/vault-mirror

# Ollama API URL (host.docker.internal reaches Ollama on the Docker host)
OLLAMA_URL=http://host.docker.internal:11434

# LLM model for L0 summary generation and query expansion
# Must be available in your Ollama instance
OLLAMA_CHAT_MODEL=qwen2.5:7b-instruct-q4_K_M

# API key for X-API-Key authentication on all endpoints
# Generate with: openssl rand -base64 32
# Leave empty to disable authentication
KB_API_KEY=

# Comma-separated directory names to skip during indexing
# .obsidian, .claude, .backups are always excluded
SKIP_DIRS_EXTRA=
